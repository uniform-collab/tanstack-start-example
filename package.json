{
  "name": "react-ssr-uniform",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "preinstall": "npx -y only-allow npm",
    "dev": "vite dev",
    "build": "vite build",
    "start": "node serve.js",
    "uniform:manifest": "uniform context manifest download --output ./lib/uniform/contextManifest.json",
    "uniform:pull": "uniform sync pull",
    "uniform:push": "uniform sync push",
    "uniform:publish": "uniform context manifest publish"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-start": "^1.168.26",
    "@uniformdev/canvas": "20.71.2-alpha.13",
    "@uniformdev/canvas-react": "20.71.2-alpha.13",
    "dotenv": "^16.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^7.13.1",
    "@typescript-eslint/parser": "^7.13.1",
    "@uniformdev/cli": "20.71.2-alpha.13",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "typescript": "^5.2.2",
    "vite": "^7.3.5"
  }
}
